# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic — for Claude Vision image-to-address extraction
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google Maps Platform — for geocoding and address validation
# Get from: https://console.cloud.google.com/ → APIs & Services → Credentials
# Enable: Geocoding API, Places API
GOOGLE_MAPS_API_KEY=AIza...

# OpenRouteService — for driving-time distance matrix (free account)
# Get from: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=...
